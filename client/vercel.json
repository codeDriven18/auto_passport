{
  "rewrites": [
    {
      "source": "/share/jobs/:id",
      "destination": "https://swipejobs-afexcuape8ecexdk.eastasia-01.azurewebsites.net/share/jobs/:id"
    },
    {
      "source": "/share/profile/:id",
      "destination": "https://swipejobs-afexcuape8ecexdk.eastasia-01.azurewebsites.net/share/profile/:id"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
